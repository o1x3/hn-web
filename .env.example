# Required: 32+ char password used by iron-session to encrypt the session cookie.
# Generate with: bunx --bun openssl rand -base64 48
SESSION_PASSWORD=replace-me-with-a-long-random-string-32-chars-min

# Optional: swap LRU cache for Upstash Redis. If both are set, Upstash is used.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional: override User-Agent reported to HN (default: hn-reddit/0.1 (+repo-url))
# HN_USER_AGENT=
